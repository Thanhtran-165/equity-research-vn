{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/site/" },
    { "source": "/assets/:path*", "destination": "/site/assets/:path*" },
    { "source": "/data/:path*", "destination": "/site/data/:path*" },
    { "source": "/chapters/:path*", "destination": "/site/chapters/:path*" }
  ]
}
