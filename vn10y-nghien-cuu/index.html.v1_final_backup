        {t:'Cổ phiếu <strong>Granger-cause</strong> bond (F=7,11 HNX), không ngược lại'}
      ]},
    { type:'quote', q:'"VN10Y là hòn đảo trong global bond market — global factor chỉ giải thích 7% biến động."',
      source:'Chương XIII — PCA / Factor Model' },
    { type:'section', num:'XVI', label:'Kết luận', title:'Tổng kết 10 phát hiện chính' },
    { type:'quote', q:'"Mọi con số chạy lại thực nghiệm được. Không ngoại suy."',
      source:'Nguyên tắc phương pháp' }
  ];

  let current = 0;
  let built = false;
  let slideEls = [];

  function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;'); }

  function renderSlide(sl, idx){
    const cls = 'slide-' + sl.type;
    let inner = '';
    if (sl.type === 'title'){
      inner = '<div class="slide-inner"><span class="badge">'+esc(sl.badge)+'</span><h1>'+esc(sl.title)+'</h1><p class="sub">'+esc(sl.sub)+'</p><p class="sub" style="color:#94a3b8;font-size:.9rem;margin-top:18px">'+esc(sl.meta)+'</p></div>';
    } else if (sl.type === 'section'){
      inner = '<div class="slide-inner"><div class="sec-num">'+esc(sl.num)+'</div><div class="sec-label">'+esc(sl.label)+'</div><h2>'+esc(sl.title)+'</h2></div>';
    } else if (sl.type === 'list'){
      const items = sl.items.map(function(it,i){ return '<li><span class="num">'+(i+1)+'</span><span class="txt">'+it.t+'</span></li>'; }).join('');
      inner = '<div class="slide-inner slide-content"><div class="kicker">'+esc(sl.kicker)+'</div><h2>'+esc(sl.title)+'</h2><ul>'+items+'</ul></div>';
    } else if (sl.type === 'quote'){
      inner = '<div class="slide-inner"><div class="qmark">"</div><p class="qtext">'+esc(sl.q)+'</p><p class="qsource">'+esc(sl.source)+'</p></div>';
    }
    return '<div class="pres-slide '+cls+(idx===0?' active':'')+'" data-idx="'+idx+'">'+inner+'</div>';
  }

  function build(){
    if (built) return;
    built = true;
    stage.innerHTML = SLIDES.map(function(sl,i){ return renderSlide(sl,i); }).join('');
    slideEls = Array.from(stage.children);
    totalEl.textContent = SLIDES.length;
    SLIDES.forEach(function(_, i){
      const d = document.createElement('button');
      d.className = 'pres-dot' + (i===0?' active':'');
      d.setAttribute('aria-label','Slide '+(i+1));
      d.addEventListener('click', function(){ goTo(i); });
      dotsBox.appendChild(d);
    });
  }

  function updateUI(){
    progressFill.style.width = ((current+1)/SLIDES.length*100)+'%';
    currentEl.textContent = current+1;
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current === SLIDES.length-1;
    Array.from(dotsBox.children).forEach(function(d,i){ d.classList.toggle('active', i===current); });
  }
  function goTo(idx){
    if (idx < 0 || idx >= SLIDES.length || idx === current) return;
    const dir = idx > current ? 'forward' : 'back';
    const old = slideEls[current];
    const nw = slideEls[idx];
    old.classList.remove('active');
    if (dir === 'forward') old.classList.add('prev'); else old.classList.remove('prev');
    nw.classList.remove('prev');
    void nw.offsetWidth;
    nw.classList.add('active');
    current = idx;
    updateUI();
  }
  function open(){ build(); overlay.classList.add('active'); overlay.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; current=0; updateUI(); }
  function close(){ overlay.classList.remove('active'); overlay.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }

  presBtn.addEventListener('click', open);
  exitBtn.addEventListener('click', close);
  prevBtn.addEventListener('click', function(){ goTo(current-1); });
  nextBtn.addEventListener('click', function(){ goTo(current+1); });
  document.addEventListener('keydown', function(e){
    if (!overlay.classList.contains('active')) return;
    if (e.key === 'ArrowRight' || e.key === ' ' || e.key === 'PageDown'){ e.preventDefault(); goTo(current+1); }
    else if (e.key === 'ArrowLeft' || e.key === 'PageUp'){ e.preventDefault(); goTo(current-1); }
    else if (e.key === 'Escape'){ close(); }
    else if (e.key === 'Home'){ goTo(0); }
    else if (e.key === 'End'){ goTo(SLIDES.length-1); }
  });
  overlay.addEventListener('click', function(e){ if (e.target === overlay) close(); });
})();

});
</script>

