(function(){
  const body = document.body;
  const minimap = document.getElementById('minimap');
  const fab = document.getElementById('mmFab');
  const closeBtn = document.getElementById('mmClose');
  const toTop = document.getElementById('toTop');
  const progressBar = document.getElementById('progressBar');
  const mmPct = document.getElementById('mmPct');
  const search = document.getElementById('mmSearch');
  const noResult = document.getElementById('mmNoResult');
  const groups = Array.from(document.querySelectorAll('.mm-group'));
  const allLinks = Array.from(document.querySelectorAll('.mm-items a'));
  const sections = allLinks.map(a => {
    const id = a.getAttribute('href').slice(1);
    return { link: a, section: document.getElementById(id), id };
  }).filter(x => x.section);

  setTimeout(() => document.body.classList.add('loaded'), 800);

  function openGroupContaining(link){
    const grp = link.closest('.mm-group');
    if (grp && !grp.classList.contains('open')) grp.classList.add('open');
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting){
        const id = entry.target.id;
        const found = sections.find(s => s.id === id);
        if (found){
          sections.forEach(s => s.link.classList.remove('active'));
          found.link.classList.add('active');
          openGroupContaining(found.link);
        }
      }
    });
  }, { rootMargin:'-90px 0px -70% 0px' });
  sections.forEach(s => observer.observe(s.section));

  function onScroll(){
    const h = document.documentElement.scrollHeight - window.innerHeight;
    const pct = Math.min(100, Math.max(0, (window.scrollY / h) * 100));
    progressBar.style.width = pct + '%';
    mmPct.textContent = Math.round(pct) + '%';
    if (window.scrollY > 400){
      body.classList.add('nav-active');
      toTop.classList.add('show');
    } else {
      body.classList.remove('nav-active');
      toTop.classList.remove('show');
    }
  }
  window.addEventListener('scroll', onScroll, { passive:true });
  onScroll();

  toTop.addEventListener('click', () => window.scrollTo({ top:0, behavior:'smooth' }));

  groups.forEach(g => {
    const head = g.querySelector('.mm-group-head');
    head.addEventListener('click', () => g.classList.toggle('open'));
  });

  search.addEventListener('input', () => {
    const q = search.value.trim().toLowerCase();
    minimap.classList.toggle('searching', !!q);
    let anyVisible = false;
    allLinks.forEach(a => {
      const text = a.textContent.toLowerCase();
      const match = !q || text.includes(q);
      a.style.display = match ? '' : 'none';
      if (match) anyVisible = true;
      if (match && q) openGroupContaining(a);
    });
    noResult.classList.toggle('show', !anyVisible);
  });

  fab.addEventListener('click', () => body.classList.add('nav-mobile-open'));
  closeBtn.addEventListener('click', () => body.classList.remove('nav-mobile-open'));

  allLinks.forEach(a => {
    a.addEventListener('click', () => {
      if (window.innerWidth < 1024) body.classList.remove('nav-mobile-open');
    });
  });
})();

