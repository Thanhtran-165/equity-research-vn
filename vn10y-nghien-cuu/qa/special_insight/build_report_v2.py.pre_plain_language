    "PCA", "phân tích thành phần chính", "synthetic control", "peak-influence",
    "cross-country", "16 trái phiếu toàn cầu", "16 global bonds", "extreme event",
    "term-β", "term beta", "r=-0,327", "r=−0,327", "β=-6,92", "β=−6,92",
    "−6,92%", "-6.92%", "Nelson-Siegel", "Diebold-Yilmaz", "Markov-switching"]
for topic in FORBIDDEN_TOPICS:
    assert topic.lower() not in html.lower(), f"BLOCKED_FORBIDDEN_TOPIC: '{topic}' found in output"

# 2. Evidence boundary appears >=2 times
eb_count = html.count("Evidence boundary")
assert eb_count >= 2, f"BLOCKED_EVIDENCE_BOUNDARY: only {eb_count} occurrences (need >=2)"

# 3. "CÙNG KỲ" on charts
assert "CÙNG KỲ" in html, "BLOCKED: 'CÙNG KỲ' missing from chart context"

# 4. 7 indices NOT called independent
assert "không độc lập" in html or "không phải 7 lần xác nhận độc lập" in html, "BLOCKED: 7 indices must be marked non-independent"

# 5. Protocol is "diễn giải" not "giao dịch"
assert "protocol diễn giải" in html.lower(), "BLOCKED: must say 'protocol diễn giải'"
assert "không phải protocol giao dịch" in html.lower() or "không phải chiến lược giao dịch" in html.lower(), "BLOCKED: must disclaim trading protocol"

# 6. No bak2-style causal mechanism claims
