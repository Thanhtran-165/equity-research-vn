<script>
(function(){
  const body = document.body;
  const minimap = document.getElementById('minimap');
  const fab = document.getElementById('mmFab');
  const closeBtn = document.getElementById('mmClose');
  const toTop = document.getElementById('toTop');
  const progressBar = document.getElementById('progressBar');
  const mmPct = document.getElementById('mmPct');
  const search = document.getElementById('mmSearch');
  const noResult = document.getElementById('mmNoResult');
  const groups = Array.from(document.querySelectorAll('.mm-group'));
  const allLinks = Array.from(document.querySelectorAll('.mm-items a'));
  const sections = allLinks.map(a => {
    const id = a.getAttribute('href').slice(1);
    return { link: a, section: document.getElementById(id), id };
  }).filter(x => x.section);

  setTimeout(() => document.body.classList.add('loaded'), 800);

  function openGroupContaining(link){
    const grp = link.closest('.mm-group');
    if (grp && !grp.classList.contains('open')) grp.classList.add('open');
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting){
        const id = entry.target.id;
        const found = sections.find(s => s.id === id);
        if (found){
          sections.forEach(s => s.link.classList.remove('active'));
          found.link.classList.add('active');
          openGroupContaining(found.link);
        }
      }
    });
  }, { rootMargin:'-90px 0px -70% 0px' });
  sections.forEach(s => observer.observe(s.section));

  function onScroll(){
    const h = document.documentElement.scrollHeight - window.innerHeight;
    const pct = Math.min(100, Math.max(0, (window.scrollY / h) * 100));
    progressBar.style.width = pct + '%';
    mmPct.textContent = Math.round(pct) + '%';
    if (window.scrollY > 400){
      body.classList.add('nav-active');
      toTop.classList.add('show');
    } else {
      body.classList.remove('nav-active');
      toTop.classList.remove('show');
    }
  }
  window.addEventListener('scroll', onScroll, { passive:true });
  onScroll();

  toTop.addEventListener('click', () => window.scrollTo({ top:0, behavior:'smooth' }));

  groups.forEach(g => {
    const head = g.querySelector('.mm-group-head');
    head.addEventListener('click', () => g.classList.toggle('open'));
  });

  search.addEventListener('input', () => {
    const q = search.value.trim().toLowerCase();
    minimap.classList.toggle('searching', !!q);
    let anyVisible = false;
    allLinks.forEach(a => {
      const text = a.textContent.toLowerCase();
      const match = !q || text.includes(q);
      a.style.display = match ? '' : 'none';
      if (match) anyVisible = true;
      if (match && q) openGroupContaining(a);
    });
    noResult.classList.toggle('show', !anyVisible);
  });

  fab.addEventListener('click', () => body.classList.add('nav-mobile-open'));
  closeBtn.addEventListener('click', () => body.classList.remove('nav-mobile-open'));

  allLinks.forEach(a => {
    a.addEventListener('click', () => {
      if (window.innerWidth < 1024) body.classList.remove('nav-mobile-open');
    });
  });
})();

(function(){
  const presBtn = document.getElementById('presBtn');
  const overlay = document.getElementById('presOverlay');
  const exitBtn = document.getElementById('presExit');
  const prevBtn = document.getElementById('presPrev');
  const nextBtn = document.getElementById('presNext');
  const stage = document.getElementById('presStage');
  const dotsBox = document.getElementById('presDots');
  const progressFill = document.getElementById('presProgress');
  const currentEl = document.getElementById('presCurrent');
  const totalEl = document.getElementById('presTotal');
  if (!presBtn || !overlay) return;

  const SLIDES = [
    { type:'title', badge:'Tự nghiên cứu · 2010–2026',
      title:'VN10Y — Một Nghiên cứu về Lợi suất Trái phiếu Việt Nam',
      sub:'16 chương · 10 phương pháp · 17 trái phiếu toàn cầu · 4.048 ngày giao dịch',
      meta:'Cập nhật 24/06/2026' },
    { type:'section', num:'I', label:'Chương 1', title:'Câu hỏi nghiên cứu' },
    { type:'list', kicker:'Phát hiện cốt lõi', title:'VN10Y ↔ VN-Index',
      items:[
        {t:'r monthly = <strong>−0,315</strong> (p &lt; 0,0001) — âm rõ ràng'},
        {t:'β = <strong>−6,67%</strong> per 1pp yield, R² = 10%'},
        {t:'Đuôi: bond top 5% → VNI <strong>−0,29%/ngày</strong> (gấp 6,6×)'},
        {t:'Cổ phiếu <strong>Granger-cause</strong> bond (F=6,49), không ngược lại'}
      ]},
    { type:'quote', q:'"VN10Y là hòn đảo trong global bond market — global factor chỉ giải thích 7% biến động."',
      source:'Chương XIII — PCA / Factor Model' },
    { type:'section', num:'XVI', label:'Kết luận', title:'Tổng kết 10 phát hiện chính' },
    { type:'quote', q:'"Mọi con số chạy lại thực nghiệm được. Không ngoại suy."',
      source:'Nguyên tắc phương pháp' }
  ];

  let current = 0;
  let built = false;
  let slideEls = [];

  function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;'); }

  function renderSlide(sl, idx){
    const cls = 'slide-' + sl.type;
    let inner = '';
    if (sl.type === 'title'){
      inner = '<div class="slide-inner"><span class="badge">'+esc(sl.badge)+'</span><h1>'+esc(sl.title)+'</h1><p class="sub">'+esc(sl.sub)+'</p><p class="sub" style="color:#94a3b8;font-size:.9rem;margin-top:18px">'+esc(sl.meta)+'</p></div>';
    } else if (sl.type === 'section'){
      inner = '<div class="slide-inner"><div class="sec-num">'+esc(sl.num)+'</div><div class="sec-label">'+esc(sl.label)+'</div><h2>'+esc(sl.title)+'</h2></div>';
    } else if (sl.type === 'list'){
      const items = sl.items.map(function(it,i){ return '<li><span class="num">'+(i+1)+'</span><span class="txt">'+it.t+'</span></li>'; }).join('');
      inner = '<div class="slide-inner slide-content"><div class="kicker">'+esc(sl.kicker)+'</div><h2>'+esc(sl.title)+'</h2><ul>'+items+'</ul></div>';
    } else if (sl.type === 'quote'){
      inner = '<div class="slide-inner"><div class="qmark">"</div><p class="qtext">'+esc(sl.q)+'</p><p class="qsource">'+esc(sl.source)+'</p></div>';
    }
    return '<div class="pres-slide '+cls+(idx===0?' active':'')+'" data-idx="'+idx+'">'+inner+'</div>';
  }

  function build(){
    if (built) return;
    built = true;
    stage.innerHTML = SLIDES.map(function(sl,i){ return renderSlide(sl,i); }).join('');
    slideEls = Array.from(stage.children);
    totalEl.textContent = SLIDES.length;
    SLIDES.forEach(function(_, i){
      const d = document.createElement('button');
      d.className = 'pres-dot' + (i===0?' active':'');
      d.setAttribute('aria-label','Slide '+(i+1));
      d.addEventListener('click', function(){ goTo(i); });
      dotsBox.appendChild(d);
    });
  }

  function updateUI(){
    progressFill.style.width = ((current+1)/SLIDES.length*100)+'%';
    currentEl.textContent = current+1;
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current === SLIDES.length-1;
    Array.from(dotsBox.children).forEach(function(d,i){ d.classList.toggle('active', i===current); });
  }
  function goTo(idx){
    if (idx < 0 || idx >= SLIDES.length || idx === current) return;
    const dir = idx > current ? 'forward' : 'back';
    const old = slideEls[current];
    const nw = slideEls[idx];
    old.classList.remove('active');
    if (dir === 'forward') old.classList.add('prev'); else old.classList.remove('prev');
    nw.classList.remove('prev');
    void nw.offsetWidth;
    nw.classList.add('active');
    current = idx;
    updateUI();
  }
  function open(){ build(); overlay.classList.add('active'); overlay.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; current=0; updateUI(); }
  function close(){ overlay.classList.remove('active'); overlay.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }

  presBtn.addEventListener('click', open);
  exitBtn.addEventListener('click', close);
  prevBtn.addEventListener('click', function(){ goTo(current-1); });
  nextBtn.addEventListener('click', function(){ goTo(current+1); });
  document.addEventListener('keydown', function(e){
    if (!overlay.classList.contains('active')) return;
    if (e.key === 'ArrowRight' || e.key === ' ' || e.key === 'PageDown'){ e.preventDefault(); goTo(current+1); }
    else if (e.key === 'ArrowLeft' || e.key === 'PageUp'){ e.preventDefault(); goTo(current-1); }
    else if (e.key === 'Escape'){ close(); }
    else if (e.key === 'Home'){ goTo(0); }
    else if (e.key === 'End'){ goTo(SLIDES.length-1); }
  });
  overlay.addEventListener('click', function(e){ if (e.target === overlay) close(); });
})();
</script>
</body>
</html>
