<!-- SCRIPT: NAVIGATION -->
<script>
(function(){
  var body=document.body;
  var minimap=document.getElementById('minimap');
  var fab=document.getElementById('mmFab');
  var closeBtn=document.getElementById('mmClose');
  var toTop=document.getElementById('toTop');
  var progressBar=document.getElementById('progressBar');
  var mmPct=document.getElementById('mmPct');
  var search=document.getElementById('mmSearch');
  var noResult=document.getElementById('mmNoResult');
  var groups=Array.from(document.querySelectorAll('.mm-group'));
  var allLinks=Array.from(document.querySelectorAll('.mm-items a'));
  var sections=allLinks.map(function(a){
    var id=a.getAttribute('href').slice(1);
    return{link:a,section:document.getElementById(id),id:id};
  }).filter(function(x){return x.section;});

  setTimeout(function(){document.body.classList.add('loaded');},600);

  function openGroupContaining(link){
    var grp=link.closest('.mm-group');
    if(grp&&!grp.classList.contains('open'))grp.classList.add('open');
  }

  var observer=new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if(entry.isIntersecting){
        var id=entry.target.id;
        var found=sections.find(function(s){return s.id===id;});
        if(found){
          sections.forEach(function(s){s.link.classList.remove('active');});
          found.link.classList.add('active');
          openGroupContaining(found.link);
        }
      }
    });
  },{rootMargin:'-90px 0px -70% 0px'});
  sections.forEach(function(s){observer.observe(s.section);});

  function onScroll(){
    var h=document.documentElement.scrollHeight-window.innerHeight;
    var pct=Math.min(100,Math.max(0,(window.scrollY/h)*100));
    progressBar.style.width=pct+'%';
    mmPct.textContent=Math.round(pct)+'%';
    if(window.scrollY>300){body.classList.add('nav-active');toTop.classList.add('show');}
    else{body.classList.remove('nav-active');toTop.classList.remove('show');}
  }
  window.addEventListener('scroll',onScroll,{passive:true});
  onScroll();

  toTop.addEventListener('click',function(){window.scrollTo({top:0,behavior:'smooth'});});

  groups.forEach(function(g){
    var head=g.querySelector('.mm-group-head');
    head.addEventListener('click',function(){g.classList.toggle('open');});
  });

  search.addEventListener('input',function(){
    var q=search.value.trim().toLowerCase();
    minimap.classList.toggle('searching',!!q);
    var anyVisible=false;
    allLinks.forEach(function(a){
      var text=a.textContent.toLowerCase();
      var match=!q||text.includes(q);
      a.style.display=match?'':'none';
      if(match)anyVisible=true;
      if(match&&q)openGroupContaining(a);
    });
    noResult.classList.toggle('show',!anyVisible);
  });

  fab.addEventListener('click',function(){body.classList.add('nav-mobile-open');});
  closeBtn.addEventListener('click',function(){body.classList.remove('nav-mobile-open');});

  allLinks.forEach(function(a){
    a.addEventListener('click',function(){
      if(window.innerWidth<1024)body.classList.remove('nav-mobile-open');
    });
  });
})();
</script>

