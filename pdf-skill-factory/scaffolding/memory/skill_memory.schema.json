{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pdf-skill-factory/skill_memory.schema.json",
  "title": "pdf-evidence skill memory",
  "description": "Memory entries for the pdf-evidence skill. Only repeated failures, reusable improvement rules, proven PDF-reading strategies, important test cases, and citation/table/legal/numeric failures. See 07-SKILL_MEMORY_SCHEMA.md for the philosophy.",
  "type": "object",
  "required": ["version", "items"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Skill version when the memory file was last appended.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "items": {
      "type": "array",
      "items": {"$ref": "#/$defs/MemoryItem"}
    }
  },
  "$defs": {
    "MemoryItem": {
      "type": "object",
      "required": ["id", "skill_name", "version", "failure_pattern", "successful_strategy", "instruction_patch", "test_case", "metric_impact", "created_at"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^M-\\d{3}$",
          "description": "Sequential memory id, never reused."
        },
        "skill_name": {
          "type": "string",
          "enum": [
            "ClassifyPDF",
            "OCRDecision",
            "ExtractEvidence",
            "ExtractTable",
            "AnswerWithCitation",
            "CompareDocuments",
            "DetectMissingEvidence",
            "RefineAnswer",
            "GenerateEvalCases",
            "UpdateSkillInstruction",
            "pdf-evidence"
          ]
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Skill version at the time this lesson was learned."
        },
        "doc_type": {
          "type": ["string", "null"],
          "description": "PDF type the lesson applies to; null if universal."
        },
        "failure_pattern": {
          "type": "string",
          "description": "Short description of the repeated failure pattern."
        },
        "failure_ids": {
          "type": "array",
          "items": {"type": "string", "pattern": "^F-?\\d{1,3}$"},
          "description": "Failure IDs (F01..F20) from 06-FAILURE_MODES.md."
        },
        "successful_strategy": {
          "type": "string",
          "description": "Proven strategy (validated by metric)."
        },
        "instruction_patch": {
          "type": "string",
          "description": "Short diff: old → new instruction text."
        },
        "test_case": {
          "type": "string",
          "description": "Fixture id or test function name that locks the lesson."
        },
        "metric_impact": {
          "type": "object",
          "required": ["metric", "before", "after"],
          "additionalProperties": false,
          "properties": {
            "metric": {"type": "string"},
            "before": {"type": "number"},
            "after": {"type": "number"}
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence in the strategy. <0.5 needs more eval."
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
