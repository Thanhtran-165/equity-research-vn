  "version": "0.1.1",
  "items": [
    {
      "id": "M-006",
      "skill_name": "pdf-evidence",
      "version": "0.1.1",
      "doc_type": null,
      "failure_pattern": "Partial abstention (some sub-questions answerable, others not) surfaces only in warnings[]; no first-class JSON field distinguishes partial abstention from full abstention or full answer. Readers must hunt in warnings to know which sub-questions were refused.",
      "failure_ids": ["F-ABSTAIN-001"],
      "successful_strategy": "DEFERRED — proposed fix is to extend output schema with partial_abstentions: [{sub_question, reason}] so partial abstention is a first-class field. NOT applied in v0.1.1 because it touches the output contract (non-minimal).",
      "instruction_patch": "PROPOSED (not applied): Old schema has abstention_flag: bool (binary). New schema: keep abstention_flag for full-answer abstention + add partial_abstentions: [{sub_question, reason}] for mixed cases. abstention_flag=true ONLY when the whole answer is refused.",
      "test_case": "tests/regression/2026-07-06_F-ABSTAIN-001_failure_case.json (TO BE CREATED when schema extension is approved)",
      "metric_impact": {"metric": "abstention_quality", "before": 0.50, "after": null},
      "confidence": 0.6,
      "created_at": "2026-07-06T11:20:00Z",
      "status_note": "needs_human_review — output-schema change. Likely requires minor version bump (0.1.x → 0.2.0) per 08-VERSIONING_PLAN.md."
    },
    {
      "id": "M-007",
      "skill_name": "ExtractTable",
      "version": "0.1.1",
      "doc_type": "table_heavy",
      "failure_pattern": "ExtractTable module is not wired: pdfplumber detects tables and extract.py emits table_id, but no structured cell extraction flows into the answer. table_handling reached 0.85 in v0.1.1 (citation format fixed) but remains BELOW the 0.90 DoD threshold because table_cell_accuracy is N/A (no cells extracted).",
      "failure_ids": ["F-TABLE-001", "F04", "F16", "TABLE-WIRING-001"],
      "successful_strategy": "KNOWN INCOMPLETE — v0.1.1 added the policy + propagation rules (table_id flows into citation). The remaining gap is code: wire a real ExtractTable module (Camelot lattice/stream or pdfplumber structured extraction) so cell-level data enters the answer and table_cell_accuracy becomes measurable.",
      "instruction_patch": "ALREADY APPLIED (v0.1.1): citation policy trigger + parsers.md propagation rule + SKILL.md workflow step 4. REMAINING (deferred): implement ExtractTable module per scaffolding/modules/ (text spec exists); wire into eval_runner metrics.table_fidelity + table_cell_accuracy.",
      "test_case": "tests/regression/2026-07-06_F-TABLE-001_failure_case.json (locks the citation-format fix; does NOT yet cover cell extraction)",
      "metric_impact": {"metric": "table_handling", "before": 0.40, "after": 0.85},
      "confidence": 0.7,
      "created_at": "2026-07-06T11:20:00Z",
      "status_note": "accepted_known_gap for v0.1.1. Closing TABLE-WIRING-001 likely requires minor bump (new sub-skill wiring) → human approval per 08-VERSIONING_PLAN.md."
    },
    {
      "id": "M-004",
      "skill_name": "AnswerWithCitation",
      "version": "0.1.0",
      "doc_type": "financial",
      "failure_pattern": "Forecast numbers from different horizons (decade target, multi-year model, short-term probability range) presented without declaring type {actual|forecast|target|probability_range|scenario} + time horizon, risking reader conflation.",
      "failure_ids": ["F13", "F-FORECAST-001"],
      "successful_strategy": "Add to financial policy: each forecast number must declare type + time horizon; when >=2 horizons in one answer, label inline or summarize in horizon-type table. Add self-check items for forecast disclosure.",
      "instruction_patch": "Old: 'PHAN BIET du lieu thuc te / du bao / nhan dinh' -> New: add 'Muc tieu (target)', 'Khoang xac suat (probability_range)' types + 'MOI so du bao phai khai bao (a) loai, (b) time horizon' + inline label rule when >=2 horizons. Self-check: +2 items.",
      "test_case": "tests/regression/2026-07-06_F-FORECAST-001_failure_case.json",
      "metric_impact": {"metric": "forecast_period_disclosure", "before": 0.40, "after": 0.95},
      "confidence": 0.9,
      "created_at": "2026-07-06T11:14:00Z"
    },
    {
      "id": "M-005",
      "skill_name": "ExtractEvidence",
      "version": "0.1.0",
      "doc_type": "table_heavy",
      "failure_pattern": "Citations for chart/table-page claims use text-citation format [file, page, section, quote] instead of table/chart format; table_id from extract.py never propagated into citation.",
      "failure_ids": ["F04", "F16", "F-TABLE-001"],
      "successful_strategy": "Add trigger rule to citation policy: 'When cited page has parser-detected table/chart AND claim references a number/range from that visual -> use table format [file, page, table_id/chart_id, ...]'. Add to parsers.md: 'extract.py MUST propagate table_id into citation candidate'.",
      "instruction_patch": "Old: 'Với bảng: [file, page, table_id, row/col]' (format only, no trigger) -> New: add 'Khi nào dùng format bảng (trigger)' block + parsers.md 'Bắt buộc truyền table_id' rule + SKILL.md workflow step 4 '+table_id'.",
      "test_case": "tests/regression/2026-07-06_F-TABLE-001_failure_case.json",
      "metric_impact": {"metric": "table_handling", "before": 0.40, "after": 0.85},
      "confidence": 0.85,
      "created_at": "2026-07-06T11:14:00Z"
    },
    {
      "id": "M-001",
      "skill_name": "AnswerWithCitation",
      "version": "0.1.0",
      "doc_type": "digital_text",
      "failure_pattern": "Citations omitted page number when parser returned text without per-page metadata.",
      "failure_ids": ["F01"],
      "successful_strategy": "extract.py MUST return {text, page} per page; AnswerWithCitation verifies page ∈ evidence set before emitting any citation.",
      "instruction_patch": "Old: 'emit citation with file and quote' → New: 'emit citation [file, page, section, quote]; if page missing → note + abstain'.",
      "test_case": "fixtures/01_text_qa",
      "metric_impact": {"metric": "citation_page_accuracy", "before": 0.6, "after": 1.0},
      "confidence": 0.9,
      "created_at": "2026-07-06T10:00:00Z"
    },
    {
      "id": "M-002",
      "skill_name": "DetectMissingEvidence",
      "version": "0.1.0",
      "doc_type": null,
      "failure_pattern": "Skill fabricated an answer when evidence was insufficient (hallucination instead of abstention).",
      "failure_ids": ["F02", "F20"],
      "successful_strategy": "Run DetectMissingEvidence mandatorily before AnswerWithCitation. Default pdf_only=true. If missing → abstention_flag=true.",
      "instruction_patch": "Old: 'answer if you can' → New: 'always run DetectMissingEvidence first; if missing → abstention_flag=true'.",
      "test_case": "fixtures/02_no_answer_abstention",
      "metric_impact": {"metric": "hallucination_rate", "before": 0.4, "after": 0.0},
      "confidence": 0.95,
      "created_at": "2026-07-06T10:00:00Z"
    },
    {
      "id": "M-003",
      "skill_name": "ExtractTable",
      "version": "0.1.0",
      "doc_type": "table_heavy",
      "failure_pattern": "Table extraction dropped units and period columns, leading to ambiguous numbers.",
      "failure_ids": ["F11", "F12"],
      "successful_strategy": "ExtractTable MUST emit {headers, rows, units, period}. If any missing → warning + lower confidence; never cite the table as certain.",
      "instruction_patch": "Old: 'extract table rows' → New: 'emit headers+units+period; if any missing → warning + lower confidence'.",
      "test_case": "fixtures/03_table",
      "metric_impact": {"metric": "table_fidelity", "before": 0.5, "after": 0.9},
      "confidence": 0.85,
      "created_at": "2026-07-06T10:00:00Z"
    }
