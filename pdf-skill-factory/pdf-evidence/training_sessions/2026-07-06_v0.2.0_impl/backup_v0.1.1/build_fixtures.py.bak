#!/usr/bin/env python3
"""build_fixtures.py — generate 5 demo PDF fixtures for pdf-evidence v0.1.

PATCH 2 — minimum 5 fixture cases. Each fixture is a directory under
scaffolding/fixtures/NN_<name>/ containing:
  - source.pdf (or source_a.pdf + source_b.pdf for multi-pdf)
  - case.json (input + expected ground-truth)

The PDFs are generated by reportlab (no copyrighted content). They are
deliberately simple text PDFs so that pdfplumber can parse them reliably
and the eval loop can run end-to-end without OCR.

Usage:
    python build_fixtures.py            # build all 5
    python build_fixtures.py --check    # verify reportlab available + show plan

After building, the eval loop is run by placing a skill_output.json next to
each case.json (the skill's actual output) and running eval_runner.py.
For v0.1 demo purposes, build_fixtures.py ALSO writes a baseline
skill_output.json for each case so the loop has something to evaluate.
These baseline outputs are realistic but should be regenerated by running
the actual pdf-evidence skill on each fixture.
"""
from __future__ import annotations

import argparse
import json
import sys
from datetime import datetime, timezone
from pathlib import Path

FIXTURES_DIR = Path(__file__).resolve().parent

try:
    from reportlab.lib.pagesizes import A4
    from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
    from reportlab.lib.units import cm
    from reportlab.platypus import (
        SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle, PageBreak,
    )
    from reportlab.lib import colors
except ImportError:
    print("ERROR: reportlab not installed. Run: pip install reportlab", file=sys.stderr)
    sys.exit(2)


def _styles():
    ss = getSampleStyleSheet()
    ss.add(ParagraphStyle(name="Body", parent=ss["Normal"], fontSize=11, leading=15, spaceAfter=6))
    ss.add(ParagraphStyle(name="H2", parent=ss["Heading2"], fontSize=13, spaceBefore=10, spaceAfter=6))
    return ss


def _save(path: Path, story):
    doc = SimpleDocTemplate(str(path), pagesize=A4, topMargin=2 * cm, bottomMargin=2 * cm)
    doc.build(story)


# ---------------------------------------------------------------------------
# Fixture 01 — text_qa
# ---------------------------------------------------------------------------

def build_01_text_qa():
    d = FIXTURES_DIR / "01_text_qa"
    d.mkdir(parents=True, exist_ok=True)
    ss = _styles()
    story = [
        Paragraph("Báo cáo Tài chính Quý 1 năm 2026", ss["Title"]),
        Spacer(1, 0.5 * cm),
        Paragraph("Công ty ABC (demo)", ss["Body"]),
        PageBreak(),
        Paragraph("Tổng quan tài chính", ss["H2"]),
        Paragraph(
            "Trong quý 1 năm 2026, công ty ABC ghi nhận doanh thu hợp nhất đạt "
            "<b>12.500 tỷ đồng</b>, tăng 11% so với cùng kỳ năm 2025. "
            "Biên lợi nhuận gộp đạt 24%, cao hơn 2 phần trăm so với mức 22% của quý 1 năm 2025.",
            ss["Body"],
        ),
        Paragraph(
            "Lợi nhuận sau thuế đạt 1.800 tỷ đồng. Tổng tài sản cuối kỳ đạt 45.000 tỷ đồng.",
            ss["Body"],
        ),
    ]
    _save(d / "source.pdf", story)

    case = {
        "id": "01_text_qa",
        "documents": [{"path": "source.pdf", "alias": "abc_2026"}],
        "question": "Doanh thu Q1/2026 của công ty ABC là bao nhiêu?",
        "task": "qa",
        "output_format": "json",
        "constraint": {"pdf_only": True, "language": "vi"},
        "expected": {
            "answer_contains": ["12.500", "tỷ"],
            "answer_not_contains": ["15.000"],
            "abstention_expected": False,
            "expected_citations": [{"page": 2, "section_keyword": "Tổng quan"}],
            "expected_numbers": ["12.500"],
            "expected_clauses": [],
            "required_points": 1,
            "answered_points": 1,
            "max_chars": None,
        },
    }
    (d / "case.json").write_text(json.dumps(case, indent=2, ensure_ascii=False), encoding="utf-8")

    # Baseline skill output (realistic; should be regenerated by the actual skill)
    baseline = {
        "answer": "Doanh thu Q1/2026 của công ty ABC là 12.500 tỷ đồng [abc_2026, p.2, 'Tổng quan tài chính', 'doanh thu hợp nhất đạt 12.500 tỷ đồng, tăng 11%'].",
        "citations": [
            {"file": "abc_2026", "page": 2, "section": "Tổng quan tài chính",
             "quote": "doanh thu hợp nhất đạt 12.500 tỷ đồng", "note": None}
        ],
        "evidence": [{"page": 2, "snippet": "doanh thu hợp nhất đạt 12.500 tỷ đồng, tăng 11%"}],
        "confidence": 0.95,
        "abstention_flag": False,
        "abstention_reason": None,
        "outside_knowledge_used": False,
        "warnings": [],
    }
    (d / "skill_output.json").write_text(json.dumps(baseline, indent=2, ensure_ascii=False), encoding="utf-8")
    print("[built] 01_text_qa")


