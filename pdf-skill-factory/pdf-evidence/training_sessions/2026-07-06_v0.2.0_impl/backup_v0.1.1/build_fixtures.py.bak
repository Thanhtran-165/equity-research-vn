# ---------------------------------------------------------------------------
# Fixture 05 — multipdf_comparison
# ---------------------------------------------------------------------------

def build_05_multipdf_comparison():
    d = FIXTURES_DIR / "05_multipdf_comparison"
    d.mkdir(parents=True, exist_ok=True)
    ss = _styles()

    # source_a.pdf — original
    story_a = [
        Paragraph("Hợp đồng dịch vụ (bản gốc, demo)", ss["Title"]),
        Spacer(1, 0.5 * cm),
        Paragraph("Điều 3. Giá trị hợp đồng", ss["H2"]),
        Paragraph("Khoản 1. Tổng giá trị hợp đồng là 10.000.000.000 đồng (mười tỷ đồng).", ss["Body"]),
        Paragraph("Điều 4. Thời hạn", ss["H2"]),
        Paragraph("Khoản 1. Hợp đồng có hiệu lực 12 tháng kể từ ngày ký.", ss["Body"]),
    ]
    _save(d / "source_a.pdf", story_a)

    # source_b.pdf — amendment
    story_b = [
        Paragraph("Phụ lục hợp đồng số 01 (demo)", ss["Title"]),
        Spacer(1, 0.5 * cm),
        Paragraph("Phụ lục này sửa đổi, bổ sung Hợp đồng dịch vụ (bản gốc).", ss["Body"]),
        Paragraph("Điều 3. Giá trị hợp đồng (sửa đổi)", ss["H2"]),
        Paragraph(
            "Khoản 1. Tổng giá trị hợp đồng được điều chỉnh thành <b>12.000.000.000 đồng</b> "
            "(mười hai tỷ đồng). Bãi bỏ Khoản 1 Điều 3 của hợp đồng gốc.",
            ss["Body"],
        ),
        Paragraph("Điều 4. Thời hạn (giữ nguyên)", ss["H2"]),
        Paragraph("Không thay đổi.", ss["Body"]),
    ]
    _save(d / "source_b.pdf", story_b)

    case = {
        "id": "05_multipdf_comparison",
        "documents": [
            {"path": "source_a.pdf", "alias": "hop_dong_goc"},
            {"path": "source_b.pdf", "alias": "phu_luc_01"},
        ],
        "question": "Phụ lục 01 đã thay đổi điều gì so với hợp đồng gốc?",
        "task": "detect_changes",
        "output_format": "json",
        "constraint": {"pdf_only": True, "language": "vi"},
        "expected": {
            "answer_contains": ["12.000.000.000", "10.000.000.000"],
            "answer_not_contains": [],
            "abstention_expected": False,
            "expected_citations": [
                {"page": 1, "section_keyword": "Điều 3"},
            ],
            "expected_numbers": ["10.000.000.000", "12.000.000.000"],
            "expected_clauses": ["Điều 3", "Khoản 1"],
            "required_points": 1,
            "answered_points": 1,
            "max_chars": None,
        },
    }
    (d / "case.json").write_text(json.dumps(case, indent=2, ensure_ascii=False), encoding="utf-8")

    baseline = {
        "answer": (
            "Phụ lục 01 thay đổi Điều 3: tổng giá trị hợp đồng tăng từ 10.000.000.000 đồng "
            "[hop_dong_goc, p.1, 'Điều 3', 'Tổng giá trị hợp đồng là 10.000.000.000 đồng'] "
            "lên 12.000.000.000 đồng [phu_luc_01, p.1, 'Điều 3', 'Tổng giá trị hợp đồng được điều chỉnh thành 12.000.000.000 đồng']. "
            "Điều 4 (thời hạn) không thay đổi [phu_luc_01, p.1, 'Điều 4', 'Không thay đổi']."
        ),
        "citations": [
            {"file": "hop_dong_goc", "page": 1, "section": "Điều 3",
             "quote": "Tổng giá trị hợp đồng là 10.000.000.000 đồng", "note": None},
            {"file": "phu_luc_01", "page": 1, "section": "Điều 3",
             "quote": "Tổng giá trị hợp đồng được điều chỉnh thành 12.000.000.000 đồng", "note": None},
            {"file": "phu_luc_01", "page": 1, "section": "Điều 4",
             "quote": "Không thay đổi", "note": None},
        ],
        "evidence": [
            {"page": 1, "snippet": "Tổng giá trị hợp đồng là 10.000.000.000 đồng"},
            {"page": 1, "snippet": "Tổng giá trị hợp đồng được điều chỉnh thành 12.000.000.000 đồng"},
            {"page": 1, "snippet": "Không thay đổi"},
        ],
        "confidence": 0.85,
        "abstention_flag": False,
        "abstention_reason": None,
        "outside_knowledge_used": False,
        "warnings": [],
    }
    (d / "skill_output.json").write_text(json.dumps(baseline, indent=2, ensure_ascii=False), encoding="utf-8")
    print("[built] 05_multipdf_comparison")


# ---------------------------------------------------------------------------

def main():
    ap = argparse.ArgumentParser(description="Build 5 demo PDF fixtures.")
    ap.add_argument("--check", action="store_true", help="Only check reportlab + show plan")
    args = ap.parse_args()

    if args.check:
        print("reportlab available. Will build: 01_text_qa, 02_no_answer_abstention, "
              "03_table, 04_legal_mock, 05_multipdf_comparison.")
        return

    build_01_text_qa()
    build_02_no_answer_abstention()
    build_03_table()
    build_04_legal_mock()
    build_05_multipdf_comparison()
    print(f"\nAll 5 fixtures built in {FIXTURES_DIR}")


if __name__ == "__main__":
    main()
