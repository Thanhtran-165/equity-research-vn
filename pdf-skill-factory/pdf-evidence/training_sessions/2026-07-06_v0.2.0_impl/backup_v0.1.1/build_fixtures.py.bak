def build_03_table():
    d = FIXTURES_DIR / "03_table"
    d.mkdir(parents=True, exist_ok=True)
    ss = _styles()
    table_data = [
        ["Chỉ tiêu", "Q1/2026 (tỷ VNĐ)", "Q1/2025 (tỷ VNĐ)"],
        ["Doanh thu", "12.500", "11.250"],
        ["Lợi nhuận gộp", "3.000", "2.475"],
        ["Lợi nhuận sau thuế", "1.800", "1.500"],
    ]
    tbl = Table(table_data, hAlign="LEFT")
    tbl.setStyle(TableStyle([
        ("BACKGROUND", (0, 0), (-1, 0), colors.lightgrey),
        ("GRID", (0, 0), (-1, -1), 0.5, colors.black),
        ("FONTNAME", (0, 0), (-1, 0), "Helvetica-Bold"),
    ]))
    story = [
        Paragraph("Báo cáo Tài chính Quý 1 năm 2026", ss["Title"]),
        Spacer(1, 0.5 * cm),
        Paragraph("Bảng tổng hợp (đơn vị: tỷ VNĐ)", ss["H2"]),
        tbl,
        Spacer(1, 0.3 * cm),
        Paragraph("Nguồn: BCTC hợp nhất Q1/2026.", ss["Body"]),
    ]
    _save(d / "source.pdf", story)

    case = {
        "id": "03_table",
        "documents": [{"path": "source.pdf", "alias": "abc_2026"}],
        "question": "Doanh thu và lợi nhuận sau thuế Q1/2026 và Q1/2025 từ bảng tổng hợp?",
        "task": "extract_table",
        "output_format": "json",
        "constraint": {"pdf_only": True, "language": "vi"},
        "expected": {
            "answer_contains": ["12.500", "1.800"],
            "answer_not_contains": [],
            "abstention_expected": False,
            "expected_citations": [{"page": 1, "section_keyword": "Bảng tổng hợp"}],
            "expected_numbers": ["12.500", "11.250", "1.800", "1.500"],
            "expected_clauses": [],
            "expected_table": {
                "headers": ["Chỉ tiêu", "Q1/2026 (tỷ VNĐ)", "Q1/2025 (tỷ VNĐ)"],
                "rows": [
                    ["Doanh thu", "12.500", "11.250"],
                    ["Lợi nhuận gộp", "3.000", "2.475"],
                    ["Lợi nhuận sau thuế", "1.800", "1.500"],
                ],
            },
            "required_points": 1,
            "answered_points": 1,
            "max_chars": None,
        },
    }
    (d / "case.json").write_text(json.dumps(case, indent=2, ensure_ascii=False), encoding="utf-8")

    baseline = {
        "answer": "Doanh thu Q1/2026: 12.500 tỷ; Q1/2025: 11.250 tỷ. LNST Q1/2026: 1.800 tỷ; Q1/2025: 1.500 tỷ [abc_2026, p.1, 'Bảng tổng hợp', bảng 1].",
        "citations": [
            {"file": "abc_2026", "page": 1, "section": "Bảng tổng hợp",
             "quote": "Bảng tổng hợp (đơn vị: tỷ VNĐ)", "note": None}
        ],
        "evidence": [{"page": 1, "snippet": "Doanh thu 12.500 / 11.250; LNST 1.800 / 1.500"}],
        "confidence": 0.85,
        "abstention_flag": False,
        "abstention_reason": None,
        "outside_knowledge_used": False,
        "warnings": ["Bảng parse có thể mất dấu hiệu merged cell — verify thủ công."],
        "expected_table": {
            "headers": ["Chỉ tiêu", "Q1/2026 (tỷ VNĐ)", "Q1/2025 (tỷ VNĐ)"],
            "rows": [
                ["Doanh thu", "12.500", "11.250"],
                ["Lợi nhuận gộp", "3.000", "2.475"],
                ["Lợi nhuận sau thuế", "1.800", "1.500"],
            ],
        },
    }
    (d / "skill_output.json").write_text(json.dumps(baseline, indent=2, ensure_ascii=False), encoding="utf-8")
    print("[built] 03_table")


