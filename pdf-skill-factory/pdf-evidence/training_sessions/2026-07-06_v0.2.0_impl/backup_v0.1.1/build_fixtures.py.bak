    baseline = {
        "answer": "Insufficient evidence in the provided documents.",
        "citations": [],
        "evidence": [{"page": 1, "snippet": "Doanh thu Q1/2026 đạt 12.500 tỷ đồng."}],
        "confidence": 0.95,
        "abstention_flag": True,
        "abstention_reason": "Tài liệu chỉ đề cập doanh thu/lợi nhuận/tổng tài sản; không có thông tin nhân sự.",
        "outside_knowledge_used": False,
        "warnings": [],
    }
    (d / "skill_output.json").write_text(json.dumps(baseline, indent=2, ensure_ascii=False), encoding="utf-8")
