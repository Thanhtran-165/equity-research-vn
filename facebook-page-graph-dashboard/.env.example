# ---- Facebook Graph API ----
# Version Graph API (lấy từ env, KHÔNG hard-code trong code)
FB_API_VERSION=v25.0

# Page ID cần theo dõi
FB_PAGE_ID=

# Page Access Token (chính) - lấy từ /me/accounts trong Graph API Explorer
FB_PAGE_ACCESS_TOKEN=

# User Access Token (optional) - chỉ dùng cho helper /api/fb/accounts
FB_USER_ACCESS_TOKEN=

# App credentials (optional) - chỉ dùng nếu muốn debug/exchange token
FB_APP_ID=
FB_APP_SECRET=

# ---- Database ----
DATABASE_URL="file:./dev.db"

# ---- Moderation tuning ----
# Số comment tối thiểu để một bài được xem xét spike
COMMENT_SPIKE_MIN_COUNT=20
# Hệ số nhân so với median comments của 25 bài gần nhất
COMMENT_SPIKE_RATIO=3

# ---- Public Competitor Benchmark (optional) ----
# Tên hiển thị của Page bạn trên bảng benchmark (mặc định lấy từ PageSnapshot)
BENCHMARK_OWN_PAGE_NAME=

# ---- Meta App Review (optional, yêu cầu khi submit App Review) ----
# Public HTTPS URL của app khi deploy (VD: https://your-app.vercel.app).
# Dùng trong /settings để show Privacy/Data Deletion URLs đầy đủ.
# Meta KHÔNG chấp nhận localhost cho App Review.
NEXT_PUBLIC_APP_URL=

# Contact email hiển thị trên /privacy, /data-deletion, /terms.
# Mặc định: stevetransg@gmail.com
NEXT_PUBLIC_CONTACT_EMAIL=stevetransg@gmail.com

# ---- Meta Exports Watched Folder (optional semi-automation) ----
META_EXPORTS_WATCH_DIR=
META_EXPORTS_INCOMING_DIR=imports/incoming
META_EXPORTS_AUTO_IMPORT=false
META_EXPORTS_CONFIRM_APPLY=false

# Cleanup controls — đưa file gốc trong Downloads vào Trash/Archive sau khi xử lý xong
META_EXPORTS_CLEANUP_MODE=none
# allowed: none | trash | archive
META_EXPORTS_ARCHIVE_DIR=imports/archive
META_EXPORTS_CLEANUP_DRY_RUN=true
META_EXPORTS_CLEANUP_AFTER=copy
# allowed: copy | upload_dry_run | apply
META_EXPORTS_CLEANUP_DUPLICATES=false
